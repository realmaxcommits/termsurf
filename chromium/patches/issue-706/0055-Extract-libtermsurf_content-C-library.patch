+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_content/ts_tab_observer.h"
+
+#include <cmath>
+
+#include "base/logging.h"
+#include "base/strings/stringprintf.h"
+#include "base/strings/utf_string_conversions.h"
+#include "content/public/browser/navigation_entry.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/render_view_host.h"
+#include "content/public/browser/render_widget_host.h"
+#include "content/public/browser/render_widget_host_view.h"
+#include "content/public/browser/web_contents.h"
+#include "content/libtermsurf_content/ts_browser_main_parts.h"
+
+#if BUILDFLAG(IS_MAC)
+#include "content/browser/renderer_host/render_widget_host_impl.h"
+#include "content/chromium_profile_server/browser/shell_ca_layer_bridge_mac.h"
+#include "content/chromium_profile_server/browser/shell_compositor_bridge_mac.h"
+#endif
+
+namespace content {
+
+TsTabObserver::TsTabObserver() = default;
+TsTabObserver::~TsTabObserver() = default;
+
+void TsTabObserver::SetTabId(int tab_id) {
+  tab_id_ = tab_id;
+}
+
+void TsTabObserver::SetInspectedTabId(int id) {
+  inspected_tab_id_ = id;
+}
+
+void TsTabObserver::ObserveContents(WebContents* web_contents) {
+  Observe(web_contents);
+}
+
+void TsTabObserver::DidFinishNavigation(
+    NavigationHandle* navigation_handle) {
+  if (!navigation_handle->HasCommitted())
+    return;
+  if (!navigation_handle->IsInPrimaryMainFrame())
+    return;
+
+#if BUILDFLAG(IS_MAC)
+  if (last_ca_context_id_)
+    *last_ca_context_id_ = 0;
+
+  std::string url;
+  if (inspected_tab_id_ > 0) {
+    url = base::StringPrintf("devtools://%d", inspected_tab_id_);
+  } else {
+    url = navigation_handle->GetURL().spec();
+  }
+
+  TsNotifyUrlChanged(reinterpret_cast<void*>(handle_), url.c_str());
+#endif
+}
+
+void TsTabObserver::DidStartLoading() {
+#if BUILDFLAG(IS_MAC)
+  TsNotifyLoadingState(reinterpret_cast<void*>(handle_), "loading", 0);
+#endif
+}
+
+void TsTabObserver::DidStopLoading() {
+#if BUILDFLAG(IS_MAC)
+  TsNotifyLoadingState(reinterpret_cast<void*>(handle_), "done", 100);
+#endif
+}
+
+void TsTabObserver::LoadProgressChanged(double progress) {
+#if BUILDFLAG(IS_MAC)
+  int pct = static_cast<int>(progress * 100);
+  if (pct >= 100) return;
+  TsNotifyLoadingState(reinterpret_cast<void*>(handle_), "progress", pct);
+#endif
+}
+
+void TsTabObserver::DidFailLoad(RenderFrameHost* render_frame_host,
+                                 const GURL& validated_url,
+                                 int error_code) {
+#if BUILDFLAG(IS_MAC)
+  if (!render_frame_host->IsInPrimaryMainFrame())
+    return;
+  TsNotifyLoadingState(reinterpret_cast<void*>(handle_), "error", 0);
+#endif
+}
+
+void TsTabObserver::TitleWasSet(NavigationEntry* entry) {
+#if BUILDFLAG(IS_MAC)
+  if (!entry)
+    return;
+  std::string title = base::UTF16ToUTF8(entry->GetTitleForDisplay());
+  TsNotifyTitleChanged(reinterpret_cast<void*>(handle_), title.c_str());
+#endif
+}
+
+#if BUILDFLAG(IS_MAC)
+void TsTabObserver::OnCursorChanged(const ui::Cursor& cursor) {
+  TsNotifyCursorChanged(reinterpret_cast<void*>(handle_), static_cast<int>(cursor.type()));
+}
+
+void TsTabObserver::SetCALayerParamsCallback(CALayerParamsCallback callback) {
+  ca_layer_params_callback_ = std::move(callback);
+}
+
+void TsTabObserver::SetLastCAContextIdPtr(uint32_t* ptr) {
+  last_ca_context_id_ = ptr;
+}
+
+void TsTabObserver::SetParentUiLayer(ui::Layer* layer) {
+  parent_ui_layer_ = layer;
+}
+
+void TsTabObserver::RenderViewHostChanged(
+    RenderViewHost* old_host, RenderViewHost* new_host) {
+  if (!new_host)
+    return;
+  auto* view = web_contents()->GetRenderWidgetHostView();
+  if (!view)
+    return;
+
+  if (ca_layer_params_callback_)
+    SetCALayerParamsCallbackOnView(view, ca_layer_params_callback_);
+
+  auto* rwhi = static_cast<RenderWidgetHostImpl*>(
+      view->GetRenderWidgetHost());
+  rwhi->SetCursorChangedCallback(base::BindRepeating(
+      &TsTabObserver::OnCursorChanged, base::Unretained(this)));
+
+  if (parent_ui_layer_) {
+    SetParentUiLayerOnView(view, parent_ui_layer_);
+  }
+}
+#endif
+
+}  // namespace content
