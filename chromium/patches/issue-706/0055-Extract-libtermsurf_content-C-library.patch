+void TsBrowserMainParts::ResizeTab(void* wc_handle, int width, int height) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  if (width <= 0 || height <= 0) return;
+
+  TabState* tab = FindTab(wc_handle);
+  if (!tab) return;
+
+  RenderWidgetHostView* view =
+      tab->shell->web_contents()->GetRenderWidgetHostView();
+  if (view) {
+    float scale = view->GetDeviceScaleFactor();
+    gfx::Size logical(
+        static_cast<int>(std::ceil(width / scale)),
+        static_cast<int>(std::ceil(height / scale)));
+    tab->shell->ResizeWebContentForTests(logical);
+  }
+
+#if BUILDFLAG(IS_MAC)
+  if (tab->compositor && tab->root_layer) {
+    RenderWidgetHostView* cv =
+        tab->shell->web_contents()->GetRenderWidgetHostView();
+    if (cv) {
+      float scale = cv->GetDeviceScaleFactor();
+      gfx::Size size_dip(
+          static_cast<int>(std::ceil(width / scale)),
+          static_cast<int>(std::ceil(height / scale)));
+      tab->root_layer->SetBounds(gfx::Rect(size_dip));
+      gfx::Size size_pixels(width, height);
+      viz::LocalSurfaceId local_surface_id =
+          viz::LocalSurfaceId(1, 1, base::UnguessableToken::Create());
+      tab->compositor->SetScaleAndSize(
+          scale, size_pixels, local_surface_id);
+    }
+  }
+#endif
+}
