+// Copyright 2025 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_LIBTERMSURF_CONTENT_TS_BROWSER_MAIN_PARTS_H_
+#define CONTENT_LIBTERMSURF_CONTENT_TS_BROWSER_MAIN_PARTS_H_
+
+#include <memory>
+#include <string>
+#include <vector>
+
+#include "base/memory/raw_ptr.h"
+#include "build/build_config.h"
+#include "content/chromium_profile_server/browser/shell_browser_main_parts.h"
+#include "third_party/blink/public/mojom/css/preferred_color_scheme.mojom.h"
+
+#if BUILDFLAG(IS_MAC)
+#include "ui/accelerated_widget_mac/accelerated_widget_mac.h"
+#include "ui/compositor/compositor.h"
+#include "ui/compositor/layer.h"
+#endif
+
+namespace content {
+
+class PersistentCompositorBridge;
+class Shell;
+class TsTabObserver;
+
+// Notification functions called by TsBrowserMainParts and TsTabObserver
+// to fire the C callbacks registered via the public API.
+void TsNotifyInitialized(class TsBrowserMainParts* parts);
+void TsNotifyTabReady(void* wc_handle, int tab_id);
+void TsNotifyCAContextId(void* wc_handle, uint32_t ca_context_id,
+                          int width, int height);
+void TsNotifyUrlChanged(void* wc_handle, const char* url);
+void TsNotifyLoadingState(void* wc_handle, const char* state, int progress);
+void TsNotifyTitleChanged(void* wc_handle, const char* title);
+void TsNotifyCursorChanged(void* wc_handle, int cursor_type);
+
+class TsBrowserMainParts : public ShellBrowserMainParts {
+ public:
+  TsBrowserMainParts();
+  ~TsBrowserMainParts() override;
+
+  TsBrowserMainParts(const TsBrowserMainParts&) = delete;
+  TsBrowserMainParts& operator=(const TsBrowserMainParts&) = delete;
+
+  // --- C API methods (called from libtermsurf_content.cc) ---
+  void* CreateBrowserContext(const char* path);
+  void DestroyBrowserContext(void* ctx);
+  void* CreateTab(void* ctx, const char* url, int width, int height, bool dark);
+  void* CreateDevToolsTab(void* ctx, void* inspected, int width, int height,
+                          bool dark);
+  void DestroyTab(void* wc_handle);
+  void NavigateTab(void* wc_handle, const char* url);
+  void ResizeTab(void* wc_handle, int width, int height);
+  void ForwardMouseEvent(void* wc_handle, int type, int button,
+                         int x, int y, int click_count, int modifiers);
+  void ForwardMouseMove(void* wc_handle, int x, int y, int modifiers);
+  void ForwardScrollEvent(void* wc_handle, int x, int y,
+                          float delta_x, float delta_y,
+                          int phase, int momentum_phase,
+                          bool precise, int modifiers);
+  void ForwardKeyEvent(void* wc_handle, int type, int keycode,
+                       const std::string& utf8, int modifiers);
+  void SetFocus(void* wc_handle, bool focused);
+  void SetColorScheme(void* wc_handle, bool dark);
+
+ protected:
+  // ShellBrowserMainParts override: fire C callback instead of starting socket.
+  void InitializeMessageLoopContext() override;
+
+ private:
+  struct TabState {
+    TabState();
+    ~TabState();
+    int tab_id = 0;
+    int inspected_tab_id = 0;
+    raw_ptr<Shell> shell;
+    std::unique_ptr<TsTabObserver> tab_observer;
+    blink::mojom::PreferredColorScheme preferred_color_scheme =
+        blink::mojom::PreferredColorScheme::kDark;
+#if BUILDFLAG(IS_MAC)
+    std::unique_ptr<ui::AcceleratedWidgetMac> widget_mac;
+    std::unique_ptr<ui::Compositor> compositor;
+    std::unique_ptr<ui::Layer> root_layer;
+    std::unique_ptr<PersistentCompositorBridge> bridge;
+#endif
+  };
+
+  TabState* FindTab(void* wc_handle);
+
+  int next_tab_id_ = 1;
+  std::vector<std::unique_ptr<TabState>> tabs_;
+};
+
+}  // namespace content
+
+#endif  // CONTENT_LIBTERMSURF_CONTENT_TS_BROWSER_MAIN_PARTS_H_
