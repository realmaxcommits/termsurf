+void* TsBrowserMainParts::CreateDevToolsTab(void* ctx, void* inspected,
+                                             int width, int height,
+                                             bool dark) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+
+  auto* browser_ctx = static_cast<ShellBrowserContext*>(ctx);
+  auto* inspected_wc = static_cast<WebContents*>(inspected);
+
+  // Find inspected tab's ID.
+  int inspected_tab_id = 0;
+  for (auto& t : tabs_) {
+    if (t->shell && t->shell->web_contents() == inspected_wc) {
+      inspected_tab_id = t->tab_id;
+      break;
+    }
+  }
+
+  GURL devtools_url(base::StringPrintf(
+      "http://127.0.0.1:%d/devtools/devtools_app.html?targetType=tab",
+      ShellDevToolsManagerDelegate::GetHttpHandlerPort()));
+
+  Shell* shell = Shell::CreateNewWindow(browser_ctx, devtools_url,
+                                        nullptr, gfx::Size());
+
+  if (width > 0 && height > 0) {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      float scale = view->GetDeviceScaleFactor();
+      gfx::Size logical(
+          static_cast<int>(std::ceil(width / scale)),
+          static_cast<int>(std::ceil(height / scale)));
+      shell->ResizeWebContentForTests(logical);
+    }
+  }
+
+  auto tab = std::make_unique<TabState>();
+  tab->shell = shell;
+  tab->inspected_tab_id = inspected_tab_id;
+  tab->preferred_color_scheme = dark
+      ? blink::mojom::PreferredColorScheme::kDark
+      : blink::mojom::PreferredColorScheme::kLight;
+
+#if BUILDFLAG(IS_MAC)
+  tab->widget_mac = std::make_unique<ui::AcceleratedWidgetMac>();
+  ui::ContextFactory* context_factory = content::GetContextFactory();
+  tab->compositor = std::make_unique<ui::Compositor>(
+      context_factory->AllocateFrameSinkId(),
+      context_factory,
+      base::SingleThreadTaskRunner::GetCurrentDefault(),
+      false);
+  tab->compositor->SetAcceleratedWidget(
+      tab->widget_mac->accelerated_widget());
+
+  tab->root_layer = std::make_unique<ui::Layer>(ui::LAYER_SOLID_COLOR);
+  tab->root_layer->SetColor(SK_ColorTRANSPARENT);
+
+  {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      float scale = view->GetDeviceScaleFactor();
+      gfx::Size size_pixels(width, height);
+      gfx::Size size_dip(
+          static_cast<int>(std::ceil(width / scale)),
+          static_cast<int>(std::ceil(height / scale)));
+      tab->root_layer->SetBounds(gfx::Rect(size_dip));
+      viz::LocalSurfaceId local_surface_id =
+          viz::LocalSurfaceId(1, 1, base::UnguessableToken::Create());
+      tab->compositor->SetScaleAndSize(
+          scale, size_pixels, local_surface_id);
+    }
+  }
+
+  tab->compositor->SetRootLayer(tab->root_layer.get());
+  tab->compositor->SetVisible(true);
+
+  tab->bridge = std::make_unique<PersistentCompositorBridge>(
+      tab->widget_mac.get());
+
+  {
+    RenderWidgetHostView* view =
+        shell->web_contents()->GetRenderWidgetHostView();
+    if (view) {
+      SetParentUiLayerOnView(view, tab->root_layer.get());
+    }
+  }
+#endif
+
+  tab->tab_id = next_tab_id_++;
+
+  void* handle = static_cast<void*>(shell->web_contents());
+
+  auto tab_observer = std::make_unique<TsTabObserver>();
+  tab_observer->SetTabId(tab->tab_id);
+  tab_observer->SetInspectedTabId(inspected_tab_id);
+  tab_observer->SetHandle(handle);
+  tab_observer->ObserveContents(shell->web_contents());
+
+  TsNotifyTabReady(handle, tab->tab_id);
+
+#if BUILDFLAG(IS_MAC)
+  if (auto* view = shell->web_contents()->GetRenderWidgetHostView()) {
+    auto* rwhi = static_cast<RenderWidgetHostImpl*>(
+        view->GetRenderWidgetHost());
+    rwhi->SetCursorChangedCallback(base::BindRepeating(
+        &TsTabObserver::OnCursorChanged,
+        base::Unretained(tab_observer.get())));
+
+    int cb_tab_id = tab->tab_id;
+    auto* last_id = new uint32_t(0);
+    void* cb_handle = handle;
+
+    auto ca_layer_callback = base::BindRepeating(
+        [](void* handle, int tab_id,
+           uint32_t* last_id, const gfx::CALayerParams& params) {
+          if (params.ca_context_id == 0 || params.ca_context_id == *last_id)
+            return;
+          *last_id = params.ca_context_id;
+          uint32_t ctx_id = params.ca_context_id;
+          int pw = params.pixel_size.width();
+          int ph = params.pixel_size.height();
+          content::GetUIThreadTaskRunner({})->PostTask(
+              FROM_HERE,
+              base::BindOnce([](void* h, uint32_t cid, int pw, int ph) {
+                TsNotifyCAContextId(h, cid, pw, ph);
+              }, handle, ctx_id, pw, ph));
+        },
+        cb_handle, cb_tab_id,
+        base::Owned(last_id));
+    SetCALayerParamsCallbackOnView(view, ca_layer_callback);
+    tab_observer->SetCALayerParamsCallback(ca_layer_callback);
+    tab_observer->SetLastCAContextIdPtr(last_id);
+
+    tab->bridge->SetCallback(base::BindRepeating(
+        [](void* handle, int tab_id,
+           uint32_t* last_id, const gfx::CALayerParams& params) {
+          if (params.ca_context_id == 0 || params.ca_context_id == *last_id)
+            return;
+          *last_id = params.ca_context_id;
+          uint32_t ctx_id = params.ca_context_id;
+          int pw = params.pixel_size.width();
+          int ph = params.pixel_size.height();
+          content::GetUIThreadTaskRunner({})->PostTask(
+              FROM_HERE,
+              base::BindOnce([](void* h, uint32_t cid, int pw, int ph) {
+                TsNotifyCAContextId(h, cid, pw, ph);
+              }, handle, ctx_id, pw, ph));
+        },
+        cb_handle, cb_tab_id,
+        base::Unretained(last_id)));
+  }
+
+  tab_observer->SetParentUiLayer(tab->root_layer.get());
+#endif
+
+  // Wire DevTools bindings.
+  WebContents* inspected_contents = nullptr;
+  for (auto& t : tabs_) {
+    if (t->shell && t->shell->web_contents() == inspected_wc) {
+      inspected_contents = t->shell->web_contents();
+      break;
+    }
+  }
+  if (inspected_contents) {
+    new ShellDevToolsFrontend(shell, inspected_contents);
+  }
+
+  tab->tab_observer = std::move(tab_observer);
+  tabs_.push_back(std::move(tab));
+
+  return handle;
+}
