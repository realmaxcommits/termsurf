@@ -5,9 +5,34 @@
 #include "content/libtermsurf_content/ts_browser_client.h"
 
 #include "content/libtermsurf_content/ts_browser_main_parts.h"
+#include "content/public/browser/render_frame_host.h"
+#include "mojo/public/cpp/bindings/binder_map.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+#include "third_party/blink/public/mojom/badging/badging.mojom.h"
 
 namespace content {
 
+// Stub BadgeService — accepts and ignores Badging API calls (Issue 655).
+// Prevents renderer kills on navigator.setAppBadge().
+class TsBrowserClient::StubBadgeService
+    : public blink::mojom::BadgeService {
+ public:
+  StubBadgeService() = default;
+  ~StubBadgeService() override = default;
+
+  void Bind(mojo::PendingReceiver<blink::mojom::BadgeService> receiver) {
+    receivers_.Add(this, std::move(receiver));
+  }
+
+  // blink::mojom::BadgeService:
+  void SetBadge(blink::mojom::BadgeValuePtr value) override {}
+  void ClearBadge() override {}
+
+ private:
+  mojo::ReceiverSet<blink::mojom::BadgeService> receivers_;
+};
+
 TsBrowserClient::TsBrowserClient() = default;
 TsBrowserClient::~TsBrowserClient() = default;
 
@@ -18,4 +43,21 @@ std::unique_ptr<BrowserMainParts> TsBrowserClient::CreateBrowserMainParts(
   return parts;
 }
 
+void TsBrowserClient::RegisterBrowserInterfaceBindersForFrame(
+    RenderFrameHost* render_frame_host,
+    mojo::BinderMapWithContext<RenderFrameHost*>* map) {
+  // Call base class first to get NetworkHintsHandler etc.
+  ShellContentBrowserClient::RegisterBrowserInterfaceBindersForFrame(
+      render_frame_host, map);
+  // Add BadgeService stub (Issue 655).
+  map->Add<blink::mojom::BadgeService>(base::BindRepeating(
+      [](TsBrowserClient* self, RenderFrameHost*,
+         mojo::PendingReceiver<blink::mojom::BadgeService> receiver) {
+        if (!self->stub_badge_service_)
+          self->stub_badge_service_ = std::make_unique<StubBadgeService>();
+        self->stub_badge_service_->Bind(std::move(receiver));
+      },
+      base::Unretained(this)));
+}
+
 }  // namespace content
