+#ifndef CONTENT_LIBTERMSURF_CONTENT_TS_COMPOSITOR_BRIDGE_MAC_H_
+#define CONTENT_LIBTERMSURF_CONTENT_TS_COMPOSITOR_BRIDGE_MAC_H_
+
+#include "base/functional/callback.h"
+#include "base/memory/raw_ptr.h"
+#include "ui/accelerated_widget_mac/accelerated_widget_mac.h"
+#include "ui/gfx/ca_layer_params.h"
+
+namespace ui { class Layer; }
+
+namespace content {
+
+class RenderWidgetHostView;
+
+void SetParentUiLayerOnView(RenderWidgetHostView* view, ui::Layer* layer);
+
+// Receives CALayerParams from a persistent AcceleratedWidgetMac and forwards
+// them via a callback. Used to extract the stable ca_context_id from the
+// persistent compositor (Issue 633).
+class PersistentCompositorBridge : public ui::AcceleratedWidgetMacNSView {
+ public:
+  using CALayerParamsCallback =
+      base::RepeatingCallback<void(const gfx::CALayerParams&)>;
+
+  explicit PersistentCompositorBridge(ui::AcceleratedWidgetMac* widget);
+  virtual ~PersistentCompositorBridge();
+
+  PersistentCompositorBridge(const PersistentCompositorBridge&) = delete;
+  PersistentCompositorBridge& operator=(const PersistentCompositorBridge&) = delete;
+
+  void SetCallback(CALayerParamsCallback callback);
+
+  // ui::AcceleratedWidgetMacNSView:
+  void AcceleratedWidgetCALayerParamsUpdated() override;
+
+ private:
+  raw_ptr<ui::AcceleratedWidgetMac> widget_;
+  CALayerParamsCallback callback_;
+};
+
+}  // namespace content
+
+#endif  // CONTENT_LIBTERMSURF_CONTENT_TS_COMPOSITOR_BRIDGE_MAC_H_
diff --git a/content/libtermsurf_content/ts_compositor_bridge_mac.mm b/content/libtermsurf_content/ts_compositor_bridge_mac.mm
new file mode 100644
