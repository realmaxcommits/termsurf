+  uint64 col = 2;
+  uint64 row = 3;
+  uint64 width = 4;
+  uint64 height = 5;
+  string url = 6;
+  string profile = 7;
+  bool browsing = 8;
+}
+
+message SetDevtoolsOverlay {
+  string pane_id = 1;
+  uint64 col = 2;
+  uint64 row = 3;
+  uint64 width = 4;
+  uint64 height = 5;
+  string profile = 6;
+  bool browsing = 7;
+  int64 inspected_tab_id = 8;
+}
+
+message OpenSplit {
+  string pane_id = 1;
+  string direction = 2;  // "horizontal" or "vertical"
