From 157941a8359cfbe07172a2c4bdfc6b597f647be2 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Wed, 4 Mar 2026 19:14:10 -0600
Subject: [PATCH 64/66] Sync proto and add DevTools debug traces

The proto was stale, the browser field lost,
DevTools sent blind at a terrible cost.
Now synced and traced from end to end,
So we can see where the messages wend.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 content/plusium/plusium_main.cc | 11 ++++++++++-
 content/plusium/termsurf.proto  |  2 ++
 2 files changed, 12 insertions(+), 1 deletion(-)

diff --git a/content/plusium/plusium_main.cc b/content/plusium/plusium_main.cc
index ea0c0048667a7..b346769d56eee 100644
--- a/content/plusium/plusium_main.cc
+++ b/content/plusium/plusium_main.cc
@@ -171,8 +171,15 @@ void HandleMessage(termsurf::TermSurfMessage* msg) {
     }
     case termsurf::TermSurfMessage::kCreateDevtoolsTab: {
       auto& m = msg->create_devtools_tab();
+      fprintf(stderr, "[DEBUG] Plusium kCreateDevtoolsTab: pane=%s inspected_tab_id=%d dark=%d\n",
+              m.pane_id().c_str(), static_cast<int>(m.inspected_tab_id()), m.dark() ? 1 : 0);
       TabEntry* inspected = FindByTabId(m.inspected_tab_id());
-      if (!inspected) break;
+      if (!inspected) {
+        fprintf(stderr, "[DEBUG] Plusium kCreateDevtoolsTab: FindByTabId FAILED for inspected_tab_id=%d\n",
+                static_cast<int>(m.inspected_tab_id()));
+        break;
+      }
+      fprintf(stderr, "[DEBUG] Plusium kCreateDevtoolsTab: inspected handle=%p\n", (void*)inspected->handle);
       // Push entry FIRST so OnTabReady can find it (it fires synchronously).
       TabEntry entry;
       entry.pane_id = m.pane_id();
@@ -184,6 +191,8 @@ void HandleMessage(termsurf::TermSurfMessage* msg) {
           static_cast<int>(m.pixel_width()),
           static_cast<int>(m.pixel_height()),
           m.dark());
+      fprintf(stderr, "[DEBUG] Plusium kCreateDevtoolsTab: handle=%p tab_id=%d\n",
+              (void*)ref.handle, ref.tab_id);
       break;
     }
     case termsurf::TermSurfMessage::kResize: {
diff --git a/content/plusium/termsurf.proto b/content/plusium/termsurf.proto
index 9c676fc73542f..d854c53df97c6 100644
--- a/content/plusium/termsurf.proto
+++ b/content/plusium/termsurf.proto
@@ -190,6 +190,7 @@ message SetOverlay {
   string url = 6;
   string profile = 7;
   bool browsing = 8;
+  string browser = 9;
 }
 
 message SetDevtoolsOverlay {
@@ -201,6 +202,7 @@ message SetDevtoolsOverlay {
   string profile = 6;
   bool browsing = 7;
   int64 inspected_tab_id = 8;
+  string browser = 9;
 }
 
 message OpenSplit {
-- 
