From 8d1d5c2801cd3c910dda4cc6bbf7dac79efd53f2 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Wed, 4 Mar 2026 18:13:05 -0600
Subject: [PATCH 61/66] Add callback traces to diagnose tab_ready
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

OnTabReady cried, "I can't find you!"
The vector was empty, the handle brand new.
We traced every call, every push, every pop—
And caught the sync callback before the push_back drop.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 content/plusium/plusium_main.cc | 22 ++++++++++++++++++++--
 1 file changed, 20 insertions(+), 2 deletions(-)

diff --git a/content/plusium/plusium_main.cc b/content/plusium/plusium_main.cc
index b33918d48bc63..6b7b5385cf281 100644
--- a/content/plusium/plusium_main.cc
+++ b/content/plusium/plusium_main.cc
@@ -151,6 +151,8 @@ void HandleMessage(termsurf::TermSurfMessage* msg) {
   switch (msg->msg_case()) {
     case termsurf::TermSurfMessage::kCreateTab: {
       auto& m = msg->create_tab();
+      fprintf(stderr, "[DEBUG] Plusium kCreateTab: pane=%s url=%s g_tabs size=%zu BEFORE ts_create_web_contents\n",
+              m.pane_id().c_str(), m.url().c_str(), g_tabs->size());
       TabEntry entry;
       entry.pane_id = m.pane_id();
       entry.handle = ts_create_web_contents(
@@ -159,7 +161,10 @@ void HandleMessage(termsurf::TermSurfMessage* msg) {
           static_cast<int>(m.pixel_width()),
           static_cast<int>(m.pixel_height()),
           m.dark());
+      fprintf(stderr, "[DEBUG] Plusium kCreateTab: handle=%p g_tabs size=%zu AFTER ts_create_web_contents, BEFORE push_back\n",
+              (void*)entry.handle, g_tabs->size());
       g_tabs->push_back(std::move(entry));
+      fprintf(stderr, "[DEBUG] Plusium kCreateTab: g_tabs size=%zu AFTER push_back\n", g_tabs->size());
       break;
     }
     case termsurf::TermSurfMessage::kCreateDevtoolsTab: {
@@ -360,8 +365,14 @@ static void OnInitialized(void*) {
 }
 
 static void OnTabReady(ts_web_contents_t wc, int tab_id, void*) {
+  fprintf(stderr, "[DEBUG] Plusium OnTabReady: handle=%p tab_id=%d g_tabs size=%zu\n",
+          (void*)wc, tab_id, g_tabs->size());
   TabEntry* t = FindByHandle(wc);
-  if (!t) return;
+  if (!t) {
+    fprintf(stderr, "[DEBUG] Plusium OnTabReady: FindByHandle FAILED — handle not in g_tabs\n");
+    return;
+  }
+  fprintf(stderr, "[DEBUG] Plusium OnTabReady: FindByHandle succeeded pane=%s\n", t->pane_id.c_str());
   t->tab_id = tab_id;
 
   termsurf::TermSurfMessage msg;
@@ -373,8 +384,15 @@ static void OnTabReady(ts_web_contents_t wc, int tab_id, void*) {
 
 static void OnCaContextId(ts_web_contents_t wc, uint32_t ca_context_id,
                            int width, int height, void*) {
+  fprintf(stderr, "[DEBUG] Plusium OnCaContextId: handle=%p ca_context_id=%u g_tabs size=%zu\n",
+          (void*)wc, ca_context_id, g_tabs->size());
   TabEntry* t = FindByHandle(wc);
-  if (!t) return;
+  if (!t) {
+    fprintf(stderr, "[DEBUG] Plusium OnCaContextId: FindByHandle FAILED\n");
+    return;
+  }
+  fprintf(stderr, "[DEBUG] Plusium OnCaContextId: FindByHandle succeeded pane=%s tab_id=%d\n",
+          t->pane_id.c_str(), t->tab_id);
 
   termsurf::TermSurfMessage msg;
   auto* m = msg.mutable_ca_context();
-- 
