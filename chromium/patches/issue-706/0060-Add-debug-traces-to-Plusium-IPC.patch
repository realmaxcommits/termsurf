From b88ceab6d76a6786d615db714f125726fef307a5 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Wed, 4 Mar 2026 18:00:22 -0600
Subject: [PATCH 60/66] Add debug traces to Plusium IPC
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

fprintf whispered secrets to stderr,
"The handshake works! But where's tab_ready?"
Case thirteen went missing in action—
Now we know where to find satisfaction.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 content/plusium/plusium_main.cc | 35 ++++++++++++++++++++++++++++++---
 1 file changed, 32 insertions(+), 3 deletions(-)

diff --git a/content/plusium/plusium_main.cc b/content/plusium/plusium_main.cc
index 0c23016ffc13f..b33918d48bc63 100644
--- a/content/plusium/plusium_main.cc
+++ b/content/plusium/plusium_main.cc
@@ -18,6 +18,7 @@
 #pragma clang diagnostic push
 #pragma clang diagnostic ignored "-Wunsafe-buffer-usage"
 
+#include <cstdio>
 #include <cstring>
 #include <string>
 #include <thread>
@@ -79,12 +80,16 @@ static void SendProtobuf(const termsurf::TermSurfMessage& msg) {
 void HandleMessage(termsurf::TermSurfMessage* msg);
 
 static void SocketReaderLoop() {
+  fprintf(stderr, "[DEBUG] Plusium SocketReaderLoop: started on fd=%d\n", g_socket_fd);
   uint8_t buf[65536];
   size_t buf_len = 0;
 
   while (true) {
     ssize_t n = read(g_socket_fd, buf + buf_len, sizeof(buf) - buf_len);
-    if (n <= 0) break;
+    if (n <= 0) {
+      fprintf(stderr, "[DEBUG] Plusium SocketReaderLoop: read returned %zd, exiting\n", n);
+      break;
+    }
     buf_len += n;
 
     while (buf_len >= 4) {
@@ -94,10 +99,14 @@ static void SocketReaderLoop() {
 
       auto* msg = new termsurf::TermSurfMessage();
       if (!msg->ParseFromArray(buf + 4, msg_len)) {
+        fprintf(stderr, "[DEBUG] Plusium SocketReaderLoop: ParseFromArray FAILED len=%u\n", msg_len);
         delete msg;
         break;
       }
 
+      fprintf(stderr, "[DEBUG] Plusium SocketReaderLoop: received msg case=%d len=%u\n",
+              static_cast<int>(msg->msg_case()), msg_len);
+
       ts_post_task([](void* data) {
         auto* m = static_cast<termsurf::TermSurfMessage*>(data);
         HandleMessage(m);
@@ -137,6 +146,8 @@ static int KeyTypeFromString(const std::string& s) {
 // --- Message dispatch (called on UI thread via ts_post_task) ---
 
 void HandleMessage(termsurf::TermSurfMessage* msg) {
+  fprintf(stderr, "[DEBUG] Plusium HandleMessage: case=%d\n",
+          static_cast<int>(msg->msg_case()));
   switch (msg->msg_case()) {
     case termsurf::TermSurfMessage::kCreateTab: {
       auto& m = msg->create_tab();
@@ -300,13 +311,26 @@ void HandleMessage(termsurf::TermSurfMessage* msg) {
 // --- C API callbacks ---
 
 static void OnInitialized(void*) {
+  fprintf(stderr, "[DEBUG] Plusium OnInitialized: creating browser context\n");
+
   // Create the browser context (uses --user-data-dir internally).
   g_browser_context = ts_create_browser_context(nullptr);
+  fprintf(stderr, "[DEBUG] Plusium OnInitialized: browser context created=%p\n",
+          (void*)g_browser_context);
 
   // Connect to GUI's Unix socket.
-  if (!g_socket_path) return;
+  if (!g_socket_path) {
+    fprintf(stderr, "[DEBUG] Plusium OnInitialized: g_socket_path is NULL, aborting\n");
+    return;
+  }
+  fprintf(stderr, "[DEBUG] Plusium OnInitialized: connecting to socket=%s\n",
+          g_socket_path);
+
   int fd = socket(AF_UNIX, SOCK_STREAM, 0);
-  if (fd < 0) return;
+  if (fd < 0) {
+    fprintf(stderr, "[DEBUG] Plusium OnInitialized: socket() failed errno=%d\n", errno);
+    return;
+  }
 
   struct sockaddr_un addr = {};
   addr.sun_family = AF_UNIX;
@@ -314,20 +338,25 @@ static void OnInitialized(void*) {
 
   if (connect(fd, reinterpret_cast<struct sockaddr*>(&addr),
               sizeof(addr)) < 0) {
+    fprintf(stderr, "[DEBUG] Plusium OnInitialized: connect() failed errno=%d\n", errno);
     close(fd);
     return;
   }
   g_socket_fd = fd;
+  fprintf(stderr, "[DEBUG] Plusium OnInitialized: connected fd=%d\n", fd);
 
   // Send ServerRegister.
   termsurf::TermSurfMessage reg_msg;
   reg_msg.mutable_server_register()->set_profile(
       g_profile_name ? g_profile_name : "");
   SendProtobuf(reg_msg);
+  fprintf(stderr, "[DEBUG] Plusium OnInitialized: sent ServerRegister profile=%s\n",
+          g_profile_name ? g_profile_name : "(empty)");
 
   // Start reader on a detached thread.
   std::thread reader(SocketReaderLoop);
   reader.detach();
+  fprintf(stderr, "[DEBUG] Plusium OnInitialized: reader thread started\n");
 }
 
 static void OnTabReady(ts_web_contents_t wc, int tab_id, void*) {
-- 
