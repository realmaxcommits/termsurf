diff --git a/content/libtermsurf_chromium/ts_pdf_navigation_throttle.cc b/content/libtermsurf_chromium/ts_pdf_navigation_throttle.cc
new file mode 100644
index 0000000000000..4488ceca954e6
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_pdf_navigation_throttle.cc
@@ -0,0 +1,160 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_pdf_navigation_throttle.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/location.h"
+#include "base/logging.h"
+#include "base/memory/weak_ptr.h"
+#include "base/strings/escape.h"
+#include "base/strings/strcat.h"
+#include "base/task/sequenced_task_runner.h"
+#include "components/pdf/common/constants.h"
+#include "content/browser/renderer_host/navigation_request.h"
+#include "content/public/browser/navigation_controller.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/web_contents.h"
+#include "net/base/filename_util.h"
+#include "net/http/http_response_headers.h"
+#include "url/gurl.h"
+
+namespace content {
+
+namespace {
+
+constexpr char kWrapperSentinel[] = "termsurf-pdf-wrapper=1";
+
+bool IsOrdinaryPdfScheme(const GURL& url) {
+  return url.SchemeIsHTTPOrHTTPS() || url.SchemeIsFile();
+}
+
+std::string HeaderMimeType(NavigationHandle* handle) {
+  const net::HttpResponseHeaders* headers = handle->GetResponseHeaders();
+  if (!headers) {
+    return std::string();
+  }
+  std::string mime_type;
+  headers->GetMimeType(&mime_type);
+  return mime_type;
+}
+
+bool LooksLikePdfUrl(const GURL& url) {
+  base::FilePath file_path;
+  return net::FileURLToFilePath(url, &file_path)
+             ? file_path.MatchesExtension(FILE_PATH_LITERAL(".pdf"))
+             : url.ExtractFileName().ends_with(".pdf");
+}
+
+std::string ResponseMimeType(NavigationHandle* handle) {
+  const std::string private_mime_type =
+      NavigationRequest::From(handle)->GetMimeType();
+  if (!private_mime_type.empty()) {
+    return private_mime_type;
+  }
+
+  const std::string header_mime_type = HeaderMimeType(handle);
+  if (!header_mime_type.empty()) {
+    return header_mime_type;
+  }
+
+  return LooksLikePdfUrl(handle->GetURL()) ? pdf::kPDFMimeType : std::string();
+}
+
+GURL BuildPdfWrapperUrl(const GURL& pdf_url) {
+  const std::string escaped_pdf_url = base::EscapeForHTML(pdf_url.spec());
+  const std::string html = base::StrCat({
+      "<!doctype html><meta charset=\"utf-8\">",
+      "<style>",
+      "html,body,embed{margin:0;width:100%;height:100%;overflow:hidden;",
+      "background:#f8d7da;}",
+      "#termsurf-pdf-wrapper-marker{position:fixed;left:6px;top:6px;",
+      "z-index:2147483647;background:#7f1d1d;color:white;",
+      "font:12px sans-serif;padding:3px 5px;}",
+      "</style>",
+      "<div id=\"termsurf-pdf-wrapper-marker\">TermSurf PDF wrapper</div>",
+      "<embed src=\"",
+      escaped_pdf_url,
+      "\" type=\"",
+      pdf::kInternalPluginMimeType,
+      "\">",
+  });
+  return GURL(base::StrCat({
+      "data:text/html;charset=utf-8;",
+      kWrapperSentinel,
+      ",",
+      base::EscapeUrlEncodedData(html, /*use_plus=*/false),
+  }));
+}
+
+void LoadWrapper(base::WeakPtr<WebContents> web_contents, GURL wrapper_url) {
+  if (!web_contents) {
+    LOG(INFO)
+        << "[issue-776-exp2] wrapper navigation skipped: WebContents gone";
+    return;
+  }
+
+  NavigationController::LoadURLParams params(wrapper_url);
+  params.is_renderer_initiated = false;
+  web_contents->GetController().LoadURLWithParams(std::move(params));
+  LOG(INFO) << "[issue-776-exp2] wrapper navigation posted url="
+            << wrapper_url.possibly_invalid_spec();
+}
+
+}  // namespace
+
+TsPdfNavigationThrottle::TsPdfNavigationThrottle(
+    NavigationThrottleRegistry& registry)
+    : NavigationThrottle(registry) {}
+
+TsPdfNavigationThrottle::~TsPdfNavigationThrottle() = default;
+
+NavigationThrottle::ThrottleCheckResult
+TsPdfNavigationThrottle::WillProcessResponse() {
+  NavigationHandle* handle = navigation_handle();
+  const GURL& url = handle->GetURL();
+  const std::string response_mime_type = ResponseMimeType(handle);
+  const std::string header_mime_type = HeaderMimeType(handle);
+  const bool is_primary_main_frame = handle->IsInPrimaryMainFrame();
+  const bool is_wrapper =
+      url.spec().find(kWrapperSentinel) != std::string::npos;
+  const bool supported_scheme = IsOrdinaryPdfScheme(url);
+
+  LOG(INFO) << "[issue-776-exp2] pdf throttle response url="
+            << url.possibly_invalid_spec()
+            << " response_mime=" << response_mime_type
+            << " header_mime=" << header_mime_type
+            << " primary_main_frame=" << is_primary_main_frame
+            << " wrapper=" << is_wrapper
+            << " supported_scheme=" << supported_scheme;
+
+  if (response_mime_type != pdf::kPDFMimeType || !is_primary_main_frame ||
+      is_wrapper || !supported_scheme) {
+    return PROCEED;
+  }
+
+  WebContents* web_contents = handle->GetWebContents();
+  if (!web_contents) {
+    LOG(INFO) << "[issue-776-exp2] proceeding: no WebContents";
+    return PROCEED;
+  }
+
+  const GURL wrapper_url = BuildPdfWrapperUrl(url);
+  LOG(INFO) << "[issue-776-exp2] canceling PDF navigation before download path"
+            << " pdf_url=" << url.possibly_invalid_spec()
+            << " wrapper_url=" << wrapper_url.possibly_invalid_spec();
+  base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&LoadWrapper, web_contents->GetWeakPtr(), wrapper_url));
+  return CANCEL_AND_IGNORE;
+}
+
+const char* TsPdfNavigationThrottle::GetNameForLogging() {
+  return "TsPdfNavigationThrottle";
+}
+
+}  // namespace content
