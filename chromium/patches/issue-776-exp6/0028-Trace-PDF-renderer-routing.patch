 #include "third_party/blink/public/platform/web_security_origin.h"
@@ -82,8 +84,7 @@ bool TsRendererClient::OverrideCreatePlugin(
     blink::WebLocalFrame* web_frame =
         render_frame ? render_frame->GetWebFrame() : nullptr;
     blink::WebFrame* parent_frame = web_frame ? web_frame->Parent() : nullptr;
-    const bool parent_origin_allowed =
-        IsAllowedPdfParentOrigin(parent_frame);
+    const bool parent_origin_allowed = IsAllowedPdfParentOrigin(parent_frame);
 
     LOG(INFO) << "[issue-776] OverrideCreatePlugin saw PDF mime=" << mime_type
               << " url=" << GURL(params.url).possibly_invalid_spec();
@@ -100,6 +101,20 @@ bool TsRendererClient::OverrideCreatePlugin(
               << " parent_origin_allowed="
               << (parent_origin_allowed ? "true" : "false");
 
+    const base::CommandLine* command_line =
+        base::CommandLine::ForCurrentProcess();
+    LOG(INFO)
+        << "[issue-776-exp4] renderer-plugin-state"
+        << " process_type="
+        << command_line->GetSwitchValueASCII(switches::kProcessType)
+        << " has_pdf_renderer_switch="
+        << (command_line->HasSwitch(switches::kPdfRenderer) ? "true" : "false")
+        << " pdf_IsPdfRenderer=" << (pdf::IsPdfRenderer() ? "true" : "false")
+        << " parent_exists=" << (parent_frame ? "true" : "false")
+        << " parent_is_remote="
+        << (parent_frame && parent_frame->IsWebRemoteFrame() ? "true" : "false")
+        << " command_line=" << command_line->GetCommandLineString();
+
     blink::WebPlugin* pdf_plugin = nullptr;
     if (parent_frame && !parent_origin_allowed) {
       const std::array<url::Origin, 1> additional_allowed_origins = {
