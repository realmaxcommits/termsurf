diff --git a/content/libtermsurf_chromium/ts_pdf_component_extension_resource_manager.cc b/content/libtermsurf_chromium/ts_pdf_component_extension_resource_manager.cc
new file mode 100644
index 0000000000000..c92a4cec05da1
--- /dev/null
+++ b/content/libtermsurf_chromium/ts_pdf_component_extension_resource_manager.cc
@@ -0,0 +1,186 @@
+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/libtermsurf_chromium/ts_pdf_component_extension_resource_manager.h"
+
+#include <algorithm>
+#include <array>
+#include <memory>
+#include <string_view>
+#include <utility>
+
+#include "base/files/file_path.h"
+#include "base/json/json_string_value_serializer.h"
+#include "base/logging.h"
+#include "base/path_service.h"
+#include "base/strings/string_util.h"
+#include "base/values.h"
+#include "chrome/grit/browser_resources.h"
+#include "chrome/grit/pdf_resources_map.h"
+#include "components/pdf/common/constants.h"
+#include "extensions/common/constants.h"
+#include "ui/base/resource/resource_bundle.h"
+#include "ui/base/webui/resource_path.h"
+
+namespace content {
+namespace {
+
+constexpr char kKnownPdfResourcePath[] = "pdf/index.html";
+constexpr char kBrowserResourcesPackPath[] = "gen/chrome/browser_resources.pak";
+constexpr char kNameTag[] = "<NAME>";
+
+bool ParseManifest(std::string_view manifest_contents) {
+  JSONStringValueDeserializer deserializer(manifest_contents);
+  std::unique_ptr<base::Value> manifest =
+      deserializer.Deserialize(nullptr, nullptr);
+  return manifest && manifest->is_dict();
+}
+
+std::string GetPdfManifestForProbe() {
+  std::string manifest_contents =
+      ui::ResourceBundle::GetSharedInstance().LoadDataResourceString(
+          IDR_PDF_MANIFEST);
+  base::ReplaceFirstSubstringAfterOffset(&manifest_contents, 0, kNameTag,
+                                         "Chromium PDF Viewer");
+  return manifest_contents;
+}
+
+}  // namespace
+
+TsPdfComponentExtensionResourceManager::ProbeResult::ProbeResult() = default;
+TsPdfComponentExtensionResourceManager::ProbeResult::ProbeResult(
+    const ProbeResult&) = default;
+TsPdfComponentExtensionResourceManager::ProbeResult&
+TsPdfComponentExtensionResourceManager::ProbeResult::operator=(
+    const ProbeResult&) = default;
+TsPdfComponentExtensionResourceManager::ProbeResult::~ProbeResult() = default;
+
+TsPdfComponentExtensionResourceManager::TsPdfComponentExtensionResourceManager()
+    : extension_info_{
+          extension_misc::kPdfExtensionId,
+          pdf::kPDFMimeType,
+          pdf::kInternalPluginMimeType,
+      } {
+  AddPdfResourceEntries();
+  RegisterTemplateReplacements();
+}
+
+TsPdfComponentExtensionResourceManager::
+    ~TsPdfComponentExtensionResourceManager() = default;
+
+bool TsPdfComponentExtensionResourceManager::IsComponentExtensionResource(
+    const base::FilePath& resource_path,
+    int* resource_id) const {
+  base::FilePath normalized_path = resource_path.NormalizePathSeparators();
+  auto entry = path_to_resource_id_.find(normalized_path);
+  if (entry == path_to_resource_id_.end()) {
+    return false;
+  }
+  if (resource_id) {
+    *resource_id = entry->second;
+  }
+  return true;
+}
+
+const ui::TemplateReplacements*
+TsPdfComponentExtensionResourceManager::GetTemplateReplacementsForExtension(
+    const std::string& extension_id) const {
+  auto entry = template_replacements_.find(extension_id);
+  if (entry == template_replacements_.end()) {
+    return nullptr;
+  }
+  return &entry->second;
+}
+
+TsPdfComponentExtensionResourceManager::ProbeResult
+TsPdfComponentExtensionResourceManager::Probe() const {
+  ProbeResult result;
+  result.browser_resources_pack_loaded = EnsureBrowserResourcesPackLoaded();
+  result.resources_registered = !path_to_resource_id_.empty();
+  result.resource_count = path_to_resource_id_.size();
+
+  const ui::TemplateReplacements* replacements =
+      GetTemplateReplacementsForExtension(extension_info_.extension_id);
+  result.template_replacements_registered =
+      replacements && !replacements->empty();
+
+  int known_resource_id = 0;
+  result.known_resource_resolved = IsComponentExtensionResource(
+      base::FilePath::FromUTF8Unsafe(kKnownPdfResourcePath),
+      &known_resource_id);
+  result.known_resource_id = known_resource_id;
+
+  std::string manifest_contents = GetPdfManifestForProbe();
+  result.manifest_parsed = ParseManifest(manifest_contents);
+
+  for (const auto& [path, _] : path_to_resource_id_) {
+    if (result.sample_paths.size() >= 3) {
+      break;
+    }
+    result.sample_paths.push_back(path.AsUTF8Unsafe());
+  }
+
+  return result;
+}
+
+void TsPdfComponentExtensionResourceManager::LogProbeResult() const {
+  ProbeResult result = Probe();
+  LOG(INFO) << "[issue-776-exp6] pdf resources registered="
+            << (result.resources_registered ? "true" : "false")
+            << " count=" << result.resource_count;
+  LOG(INFO) << "[issue-776-exp6] pdf template replacements registered="
+            << (result.template_replacements_registered ? "true" : "false");
+  LOG(INFO) << "[issue-776-exp6] pdf manifest parsed="
+            << (result.manifest_parsed ? "true" : "false");
+  LOG(INFO) << "[issue-776-exp6] pdf known resource resolved="
+            << (result.known_resource_resolved ? "true" : "false")
+            << " path=" << kKnownPdfResourcePath
+            << " id=" << result.known_resource_id;
+  LOG(INFO) << "[issue-776-exp6] pdf extension id="
+            << extension_info_.extension_id
+            << " pdf_mime=" << extension_info_.pdf_mime_type
+            << " internal_plugin_mime="
+            << extension_info_.internal_plugin_mime_type;
+  LOG(INFO) << "[issue-776-exp6] browser resources pack loaded="
+            << (result.browser_resources_pack_loaded ? "true" : "false");
+  for (const std::string& path : result.sample_paths) {
+    LOG(INFO) << "[issue-776-exp6] pdf resource sample=" << path;
+  }
+}
+
+void TsPdfComponentExtensionResourceManager::AddPdfResourceEntries() {
+  for (const webui::ResourcePath& entry : kPdfResources) {
+    base::FilePath resource_path =
+        base::FilePath::FromUTF8Unsafe(entry.path).NormalizePathSeparators();
+    path_to_resource_id_.try_emplace(std::move(resource_path), entry.id);
+  }
+}
+
+void TsPdfComponentExtensionResourceManager::RegisterTemplateReplacements() {
+  ui::TemplateReplacements replacements;
+  replacements["name"] = "Chromium PDF Viewer";
+  replacements["errorDialogTitle"] = "Couldn't load PDF";
+  replacements["pageLoading"] = "Loading...";
+  replacements["pageLoadFailed"] = "Failed to load PDF document.";
+  replacements["pageReload"] = "Reload";
+  template_replacements_[extension_info_.extension_id] =
+      std::move(replacements);
+}
+
+bool TsPdfComponentExtensionResourceManager::EnsureBrowserResourcesPackLoaded()
+    const {
+  base::FilePath assets_path;
+  if (!base::PathService::Get(base::DIR_ASSETS, &assets_path)) {
+    return false;
+  }
+
+  base::FilePath browser_resources_pack =
+      assets_path.AppendASCII(kBrowserResourcesPackPath);
+  ui::ResourceBundle::GetSharedInstance().AddDataPackFromPath(
+      browser_resources_pack, ui::kScaleFactorNone);
+  return ui::ResourceBundle::GetSharedInstance().HasDataResource(
+      IDR_PDF_MANIFEST);
+}
+
+}  // namespace content
