+// Copyright 2026 TermSurf
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_LIBTERMSURF_CHROMIUM_TS_PDF_COMPONENT_EXTENSION_RESOURCE_MANAGER_H_
+#define CONTENT_LIBTERMSURF_CHROMIUM_TS_PDF_COMPONENT_EXTENSION_RESOURCE_MANAGER_H_
+
+#include <cstddef>
+#include <map>
+#include <string>
+#include <vector>
+
+#include "base/files/file_path.h"
+#include "ui/base/template_expressions.h"
+
+namespace content {
+
+struct TsPdfExtensionInfo {
+  const char* extension_id;
+  const char* pdf_mime_type;
+  const char* internal_plugin_mime_type;
+};
+
+class TsPdfComponentExtensionResourceManager {
+ public:
+  struct ProbeResult {
+    ProbeResult();
+    ProbeResult(const ProbeResult&);
+    ProbeResult& operator=(const ProbeResult&);
+    ~ProbeResult();
+
+    bool resources_registered = false;
+    bool template_replacements_registered = false;
+    bool manifest_parsed = false;
+    bool known_resource_resolved = false;
+    bool browser_resources_pack_loaded = false;
+    int known_resource_id = 0;
+    size_t resource_count = 0;
+    std::vector<std::string> sample_paths;
+  };
+
+  TsPdfComponentExtensionResourceManager();
+  ~TsPdfComponentExtensionResourceManager();
+
+  TsPdfComponentExtensionResourceManager(
+      const TsPdfComponentExtensionResourceManager&) = delete;
+  TsPdfComponentExtensionResourceManager& operator=(
+      const TsPdfComponentExtensionResourceManager&) = delete;
+
+  const TsPdfExtensionInfo& extension_info() const { return extension_info_; }
+
+  bool IsComponentExtensionResource(const base::FilePath& resource_path,
+                                    int* resource_id) const;
+  const ui::TemplateReplacements* GetTemplateReplacementsForExtension(
+      const std::string& extension_id) const;
+
+  ProbeResult Probe() const;
+  void LogProbeResult() const;
+
+ private:
+  void AddPdfResourceEntries();
+  void RegisterTemplateReplacements();
+  bool EnsureBrowserResourcesPackLoaded() const;
+
+  TsPdfExtensionInfo extension_info_;
+  std::map<base::FilePath, int> path_to_resource_id_;
+  std::map<std::string, ui::TemplateReplacements> template_replacements_;
+};
+
+}  // namespace content
+
+#endif  // CONTENT_LIBTERMSURF_CHROMIUM_TS_PDF_COMPONENT_EXTENSION_RESOURCE_MANAGER_H_
