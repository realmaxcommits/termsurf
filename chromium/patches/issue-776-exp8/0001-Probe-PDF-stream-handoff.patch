   auto* browser_context = web_contents->GetBrowserContext();
 
+#if BUILDFLAG(ENABLE_PDF)
+  if (extension_id == extension_misc::kPdfExtensionId) {
+    const bool oopif_pdf_enabled = chrome_pdf::features::IsOopifPdfEnabled();
+    LOG(INFO) << "[issue-776-exp8] stream-dispatch extension_id="
+              << extension_id
+              << " original_url=" << original_url.possibly_invalid_spec()
+              << " frame_tree_node_id=" << frame_tree_node_id
+              << " internal_id=" << internal_id
+              << " embedded=" << (embedded ? "true" : "false")
+              << " oopif_pdf_enabled="
+              << (oopif_pdf_enabled ? "true" : "false");
+    if (!oopif_pdf_enabled) {
+      LOG(INFO)
+          << "[issue-776-exp8] stream-dispatch-aborted reason=oopif-disabled";
+      return;
+    }
+
+    GURL handler_url(Extension::GetBaseURLFromExtensionId(extension_id).spec() +
+                     "pdf/index.html");
+    auto stream_container = std::make_unique<StreamContainer>(
+        /*tab_id=*/-1, embedded, handler_url, extension_id,
+        std::move(transferrable_loader), original_url);
+    pdf::PdfViewerStreamManager::Create(web_contents);
+    auto* stream_manager =
+        pdf::PdfViewerStreamManager::FromWebContents(web_contents);
+    stream_manager->AddStreamContainer(frame_tree_node_id, internal_id,
+                                       std::move(stream_container));
+    LOG(INFO) << "[issue-776-exp8] stream-container-added extension_id="
+              << extension_id
+              << " original_url=" << original_url.possibly_invalid_spec()
+              << " handler_url=" << handler_url.possibly_invalid_spec()
+              << " frame_tree_node_id=" << frame_tree_node_id
+              << " internal_id=" << internal_id
+              << " embedded=" << (embedded ? "true" : "false");
+    return;
+  }
+#endif  // BUILDFLAG(ENABLE_PDF)
+
   const Extension* extension = ExtensionRegistry::Get(browser_context)
                                    ->enabled_extensions()
                                    .GetByID(extension_id);
