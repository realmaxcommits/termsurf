+void ShellBrowserMainParts::StartSocketMode(
+    const std::string& socket_path) {
+  // Connect to GUI's Unix socket.
+  int fd = socket(AF_UNIX, SOCK_STREAM, 0);
+  if (fd < 0) {
+    LOG(ERROR) << "[ProfileServer] socket() failed: " << strerror(errno);
+    return;
+  }
+  struct sockaddr_un addr = {};
+  addr.sun_family = AF_UNIX;
+  UNSAFE_BUFFERS(
+      strncpy(addr.sun_path, socket_path.c_str(), sizeof(addr.sun_path) - 1));
+
+  if (connect(fd, reinterpret_cast<struct sockaddr*>(&addr),
+              sizeof(addr)) < 0) {
+    LOG(ERROR) << "[ProfileServer] Socket connect failed: " << strerror(errno);
+    close(fd);
+    return;
+  }
+  socket_fd_ = fd;
+
+  // Derive profile from --user-data-dir basename.
+  std::string profile;
+  base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (cmd->HasSwitch(switches::kChromiumProfileServerUserDataDir)) {
+    base::FilePath data_dir =
+        cmd->GetSwitchValuePath(switches::kChromiumProfileServerUserDataDir);
+    profile = data_dir.BaseName().value();
+  }
+
+  // Send ServerRegister.
+  termsurf::TermSurfMessage reg_msg;
+  reg_msg.mutable_server_register()->set_profile(profile);
+  SendProtobuf(reg_msg);
+
+  LOG(INFO) << "[ProfileServer] Socket connected to " << socket_path
+            << ", profile=" << profile;
+
+  // Start reader on a detached thread.
+  std::thread reader([this]() { SocketReaderLoop(); });
+  reader.detach();
+}
+
+void ShellBrowserMainParts::SendProtobuf(
+    const termsurf::TermSurfMessage& msg) {
+  if (socket_fd_ < 0) return;
+  size_t size = msg.ByteSizeLong();
+  std::vector<uint8_t> buf(4 + size);
+  uint32_t len = static_cast<uint32_t>(size);
+  buf[0] = len & 0xFF;
+  buf[1] = (len >> 8) & 0xFF;
+  buf[2] = (len >> 16) & 0xFF;
+  buf[3] = (len >> 24) & 0xFF;
+  msg.SerializeToArray(&buf[4], size);
+  write(socket_fd_, buf.data(), buf.size());
+}
+
+void ShellBrowserMainParts::SocketReaderLoop() {
+  // SAFETY: Manual buffer management for socket framing protocol.
+  // buf is a fixed 64K array, buf_len tracks used portion.
+  UNSAFE_BUFFERS({
+    uint8_t buf[65536];
+    size_t buf_len = 0;
+
+    while (true) {
+      ssize_t n = read(socket_fd_, buf + buf_len, sizeof(buf) - buf_len);
+      if (n <= 0) break;
+      buf_len += n;
+
+      while (buf_len >= 4) {
+        uint32_t msg_len = buf[0] | (buf[1] << 8) |
+                            (buf[2] << 16) | (buf[3] << 24);
+        if (buf_len < 4 + msg_len) break;
+
+        auto msg = std::make_unique<termsurf::TermSurfMessage>();
+        if (!msg->ParseFromArray(buf + 4, msg_len)) {
+          LOG(ERROR) << "[ProfileServer] Failed to parse socket protobuf";
+          break;
+        }
+
+        ShellBrowserMainParts* self = this;
+        content::GetUIThreadTaskRunner({})->PostTask(
+            FROM_HERE,
+            base::BindOnce(&ShellBrowserMainParts::HandleSocketMsg,
+                           base::Unretained(self), std::move(msg)));
+
+        size_t consumed = 4 + msg_len;
+        if (consumed < buf_len)
+          memmove(buf, buf + consumed, buf_len - consumed);
+        buf_len -= consumed;
+      }
+    }
+    LOG(INFO) << "[ProfileServer] Socket reader exiting";
+  });
+}
+
+void ShellBrowserMainParts::HandleSocketMsg(
+    std::unique_ptr<termsurf::TermSurfMessage> msg) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+
+  switch (msg->msg_case()) {
+    case termsurf::TermSurfMessage::kCreateTab: {
+      auto& m = msg->create_tab();
+      CreateTab(GURL(m.url()), m.pane_id(),
+                m.pixel_width(), m.pixel_height(), m.dark());
+      break;
+    }
+    case termsurf::TermSurfMessage::kCreateDevtoolsTab: {
+      auto& m = msg->create_devtools_tab();
+      CreateDevToolsTab(m.pane_id(), m.inspected_tab_id(),
+                        m.pixel_width(), m.pixel_height(), m.dark());
+      break;
+    }
+    case termsurf::TermSurfMessage::kResize: {
+      auto& m = msg->resize();
+      ResizeTab(m.tab_id(), m.pixel_width(), m.pixel_height());
+      break;
+    }
+    case termsurf::TermSurfMessage::kCloseTab: {
+      CloseTabById(msg->close_tab().tab_id());
+      break;
+    }
+    case termsurf::TermSurfMessage::kNavigate: {
+      auto& m = msg->navigate();
+      NavigateTab(m.tab_id(), GURL(m.url()));
+      break;
+    }
+    case termsurf::TermSurfMessage::kMouseEvent: {
+      auto& m = msg->mouse_event();
+      HandleMouseEvent(m.tab_id(), m.type(), m.x(), m.y(),
+                       m.button(), m.click_count(), m.modifiers());
+      break;
+    }
+    case termsurf::TermSurfMessage::kMouseMove: {
+      auto& m = msg->mouse_move();
+      HandleMouseMove(m.tab_id(), m.x(), m.y(), m.modifiers());
+      break;
+    }
+    case termsurf::TermSurfMessage::kScrollEvent: {
+      auto& m = msg->scroll_event();
+      HandleScrollEvent(m.tab_id(), m.x(), m.y(),
+                        m.delta_x(), m.delta_y(),
+                        m.phase(), m.momentum_phase(),
+                        m.precise(), m.modifiers());
+      break;
+    }
+    case termsurf::TermSurfMessage::kKeyEvent: {
+      auto& m = msg->key_event();
+      HandleKeyEvent(m.tab_id(), m.type(),
+                     m.windows_key_code(), m.utf8(), m.modifiers());
+      break;
+    }
+    case termsurf::TermSurfMessage::kFocusChanged: {
+      auto& m = msg->focus_changed();
+      HandleFocusChanged(m.tab_id(), m.focused());
+      break;
+    }
+    case termsurf::TermSurfMessage::kSetColorScheme: {
+      auto& m = msg->set_color_scheme();
+      SetColorScheme(m.tab_id(), m.dark());
+      break;
+    }
+    case termsurf::TermSurfMessage::kQueryTabsRequest: {
+      HandleQueryTabsSocket();
+      break;
+    }
+    default:
+      LOG(WARNING) << "[ProfileServer] Unknown socket msg_case="
+                   << msg->msg_case();
+      break;
+  }
+}
+
+void ShellBrowserMainParts::HandleQueryTabsSocket() {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+
+  int64_t total = static_cast<int64_t>(tabs_.size());
+  int64_t browser_count = 0;
+  int64_t devtools_count = 0;
+
+  for (auto& tab : tabs_) {
+    if (tab->inspected_tab_id > 0)
+      devtools_count++;
+    else
+      browser_count++;
+  }
+
+  termsurf::TermSurfMessage reply_msg;
+  auto* reply = reply_msg.mutable_query_tabs_reply();
+  reply->set_chromium_tabs(total);
+  reply->set_chromium_browser(browser_count);
+  reply->set_chromium_devtools(devtools_count);
+
+  for (auto& tab : tabs_) {
+    auto* ti = reply->add_tabs();
+    ti->set_id(tab->tab_id);
+    ti->set_inspected_tab_id(tab->inspected_tab_id);
+    ti->set_pane_id(tab->pane_id);
+    ti->set_url(tab->shell->web_contents()->GetURL().spec());
+  }
+
+  SendProtobuf(reply_msg);
+  LOG(INFO) << "[ProfileServer] query_tabs (socket): " << total
+            << " tabs (" << browser_count << " browser, "
+            << devtools_count << " devtools)";
+}
